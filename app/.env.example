# API Configuration
# En desarrollo: usa la IP local de tu PC (no localhost)
# Para encontrar tu IP: ipconfig (Windows) o ifconfig (Mac/Linux)
API_BASE_URL_DEV=http://192.168.1.X:3000/api/v1

# En produccion: usa la URL real del servidor
API_BASE_URL_PROD=https://api.nexus.unisabana.edu.co/api/v1

# Microsoft OAuth (pendiente de registro en Azure AD)
MICROSOFT_CLIENT_ID=YOUR_CLIENT_ID_HERE
MICROSOFT_TENANT_ID=YOUR_TENANT_ID_HERE
